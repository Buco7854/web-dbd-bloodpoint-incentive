{
  "name": "bloodpoint-incentives",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Live Dead by Daylight Bloodpoint incentives viewer (unofficial fan project).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n hub,web -c blue,magenta \"npm:dev:hub\" \"npm:dev:web\"",
    "dev:hub": "go run ./cmd/hub",
    "dev:agent": "tsx watch src/agent/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:agent && npm run build:hub",
    "build:web": "vite build",
    "build:agent": "tsup",
    "build:hub": "go build -o dist/bloodpoint-hub ./cmd/hub",
    "render:og": "node scripts/render-og.mjs",
    "render:favicons": "node scripts/render-favicons.mjs",
    "start": "./dist/bloodpoint-hub",
    "start:hub": "./dist/bloodpoint-hub",
    "start:agent": "node dist/agent/index.cjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:go": "go test ./...",
    "docs:dev": "npm run docs:spec && npm run docs:icons && vitepress dev docs",
    "docs:build": "npm run docs:spec && npm run docs:icons && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:spec": "ORIGIN=https://bpincentives.com go run ./cmd/hub openapi json > docs/public/openapi.json",
    "docs:icons": "cp src/web/public/favicon.svg src/web/public/favicon-32.png src/web/public/favicon-192.png src/web/public/favicon.ico src/web/public/apple-touch-icon.png docs/public/"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "vitepress-openapi": "^0.2.0"
  },
  "optionalDependencies": {
    "steam-totp": "^2.1.2",
    "steam-user": "^5.2.0"
  },
  "devDependencies": {
    "@fontsource/oswald": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hammerjs": "^2.0.46",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "country-flag-icons": "^1.6.19",
    "hammerjs": "^2.0.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitepress": "^1.6.4"
  }
}
